
{


 "files.associations": {
    "*.yaml": "yaml",
    "*.yml": "yaml"
  },

  "ansible.ansible.enabled": false,
  "ansible.lightspeed.enabled": false,

  "terraform.languageServer.enable": false,

  "docker.enableDockerfileLanguageFeatures": false,

  "yaml.validate": true,
  "yaml.completion": true,
  "vs-kubernetes.enable": true,
"yyyaml.kubernetes": true,

"yaml.validate": true,
    "yaml.schemas": {

        "https://raw.githubusercontent.com/compose-spec/compose-spec/master/schema/compose-spec.json": [
            "docker-compose.yml",
            "docker-compose.yaml",
            "Docker-compose.yml",
            "Docker-compose.yaml",
            "compose.yml",
            "compose.yaml"
        ],
	"https://raw.githubusercontent.com/yannh/kubernetes-json-schema/master/v1.35.0-standalone-strict/all.json": [
      	"/**/*.yaml",
      	"/**/*.yaml"
    	]





    },
    "yaml.customTags": [


    ]
}
