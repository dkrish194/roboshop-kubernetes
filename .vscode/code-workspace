{
  "folders": [
    { "path": "." }
  ],

  "settings": {
    "yaml.validate": true,
    "yaml.schemas": {
      "https://raw.githubusercontent.com/yannh/kubernetes-json-schema/master/v1.29.0-standalone-strict/all.json": [
        "k8s/**/*.yaml",
        "manifests/**/*.yaml"
      ]
    },
    "files.watcherExclude": {
      "**/.terraform/**": true,
      "**/node_modules/**": true
    },
    "ansible.ansible.enabled": false,
    "terraform.languageServer.enable": false,
    "editor.formatOnSave": true
  },

  "extensions": {
    "recommendations": [
      "redhat.vscode-yaml",
      "ms-kubernetes-tools.vscode-kubernetes-tools",
      "Tim-Koehler.helm-intellisense"
    ],
    "unwantedRecommendations": [
      "redhat.ansible",
      "hashicorp.terraform"
    ]
  },

  "launch": {
    "configurations": []
  }
}
